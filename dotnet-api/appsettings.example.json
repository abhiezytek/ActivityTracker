{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=<DB_HOST>;Port=3306;Database=activity_tracker;User=<DB_USER>;Password=<DB_PASSWORD>;"
  },
  "Jwt": {
    "Secret": "<your-super-secret-jwt-key-min-32-characters>",
    "ExpiresInHours": 24,
    "Issuer": "ActivityTrackerAPI",
    "Audience": "ActivityTrackerClient"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:5173" ]
  }
}
